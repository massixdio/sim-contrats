# Variables d'environnement pour le déploiement en production (docker-compose.prod.yml).
# Sur Dokploy : coller ces variables (avec de vraies valeurs) dans l'onglet
# "Environment" de l'application, PAS dans un fichier .env committé sur le VPS.
#
# Génération de secrets forts :
#   openssl rand -base64 32

# --- PostgreSQL ---
POSTGRES_USER=insurance_prod
POSTGRES_PASSWORD=change_me_generate_a_strong_random_password
POSTGRES_DB=insurance_db

# --- Backend ---
JWT_SECRET=change_me_generate_with_openssl_rand_base64_32
JWT_EXPIRES_IN=7d
# URL publique du frontend (autorisée par CORS). Doit correspondre au domaine
# configuré dans Dokploy pour le service frontend.
CORS_ORIGIN=https://app.votredomaine.com

# --- Frontend ---
# Origine publique de l'API (SANS /api à la fin, le préfixe est ajouté par le code),
# injectée dans le bundle au moment du build (Vite). Doit correspondre au domaine
# configuré dans Dokploy pour le service backend.
VITE_API_URL=https://api.votredomaine.com
