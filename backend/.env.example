# Utilisé uniquement quand le backend tourne en local (npm run dev), en dehors de Docker,
# et se connecte au Postgres du docker-compose via son port publié sur l'hôte (localhost).
# Si le backend tourne lui-même dans docker-compose, c'est le DATABASE_URL défini dans
# docker-compose.yml (host "postgres") qui est utilisé, pas ce fichier.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://insurance:insurance@localhost:5432/insurance_db?schema=public
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
