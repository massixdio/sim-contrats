# Utilisé par docker-compose.yml pour orchestrer les 3 services (postgres, backend, frontend).
# Ne PAS confondre avec backend/.env ou frontend/.env, qui servent uniquement au développement
# local hors Docker (npm run dev exécuté directement sur la machine hôte).

# Postgres
POSTGRES_USER=insurance
POSTGRES_PASSWORD=insurance
POSTGRES_DB=insurance_db
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=4000
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:4000/api
